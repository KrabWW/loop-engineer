#!/usr/bin/env bash

set -euo pipefail

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)
tmux_shim="${script_dir}/omc-runtime-bin/tmux"

fail() {
  printf 'ERROR: %s\n' "$*" >&2
  exit 1
}

usage() {
  printf '%s\n' \
    'Usage: ./scripts/start-omc-task [--dry-run] [--allow-derived-ready] <TASK_ID>' \
    '' \
    'Create one clean Task integration worktree and start its OMC team in tmux.'
}

read_field() {
  field=$1
  file=$2
  awk -v field="$field" '
    index($0, field ": ") == 1 {
      line = $0
      sub(/^[^:]+: /, "", line)
      gsub(/`/, "", line)
      print line
      exit
    }
  ' "$file"
}

find_task_file() {
  wanted_id=$1
  matches=$(rg -l --glob '*.md' -- "^# ${wanted_id}( |$)" docs/tasks 2>/dev/null || true)
  count=$(printf '%s\n' "$matches" | awk 'NF { count += 1 } END { print count + 0 }')
  [ "$count" -eq 1 ] || fail "expected one task file for ${wanted_id}, found ${count}"
  printf '%s\n' "$matches"
}

task_goal() {
  awk '
    /^## Goal[[:space:]]*$/ { in_goal = 1; next }
    in_goal && /^## / { exit }
    in_goal && NF {
      line = $0
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
      text = text (text == "" ? "" : " ") line
    }
    END { print text }
  ' "$1"
}

task_allows_file() {
  wanted=$1
  file=$2
  allowed=$(awk '
    /^## Allowed Files[[:space:]]*$/ { in_allowed = 1; next }
    in_allowed && /^## / { exit }
    in_allowed { print }
  ' "$file"
  )
  printf '%s\n' "$allowed" | rg -F -x -- "- \`${wanted}\`" >/dev/null
}

reference_fingerprint() {
  python3 - "$1" <<'PY'
import hashlib
import os
from pathlib import Path
import stat
import sys

root = Path(sys.argv[1])
digest = hashlib.sha256()
digest.update(b"content-v2\n")
if not root.exists():
    digest.update(b"absent\n")
else:
    for current, dirs, files in os.walk(root):
        dirs[:] = sorted(name for name in dirs if name not in {".git", ".omc", ".omx"})
        files = sorted(name for name in files if name != ".DS_Store")
        current_path = Path(current)
        for name in dirs + files:
            path = current_path / name
            info = os.lstat(path)
            relative = path.relative_to(root).as_posix()
            mode = stat.S_IMODE(info.st_mode)
            if stat.S_ISLNK(info.st_mode):
                record = f"link\0{relative}\0{mode:o}\0{os.readlink(path)}\n".encode()
            elif stat.S_ISREG(info.st_mode):
                content = hashlib.sha256(path.read_bytes()).hexdigest()
                record = f"file\0{relative}\0{mode:o}\0{content}\n".encode()
            elif stat.S_ISDIR(info.st_mode):
                record = f"dir\0{relative}\0{mode:o}\n".encode()
            else:
                record = f"special\0{relative}\0{info.st_mode}\n".encode()
            digest.update(record)
print(digest.hexdigest())
PY
}

dry_run=0
allow_derived_ready=0
while [ "$#" -gt 0 ]; do
  case "$1" in
    --dry-run) dry_run=1; shift ;;
    --allow-derived-ready) allow_derived_ready=1; shift ;;
    -h|--help) usage; exit 0 ;;
    --*) fail "unknown option: $1" ;;
    *) break ;;
  esac
done
if [ "${1:-}" = '-h' ] || [ "${1:-}" = '--help' ]; then
  usage
  exit 0
fi
[ "$#" -eq 1 ] || { usage >&2; exit 2; }

task_id=$1
[[ "$task_id" =~ ^[A-Z][A-Z0-9-]+$ ]] || fail "invalid TASK_ID: ${task_id}"

for command_name in git rg bash df env python3 find; do
  command -v "$command_name" >/dev/null 2>&1 || fail "required command not found: ${command_name}"
done

omc_bin=${OMC_BIN:-omc}
tmux_bin=${TMUX_BIN:-tmux}
df_bin=${DF_BIN:-df}
command -v "$omc_bin" >/dev/null 2>&1 || fail "required OMC command not found: ${omc_bin}"
command -v "$tmux_bin" >/dev/null 2>&1 || fail "required tmux command not found: ${tmux_bin}"
command -v "$df_bin" >/dev/null 2>&1 || fail "required df command not found: ${df_bin}"
tmux_real_bin=$(command -v "$tmux_bin")
[ -x "$tmux_shim" ] || fail "required OMC tmux shim not found or not executable: ${tmux_shim}"

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || fail 'not inside a Git repository'
repo_root=$(cd "$repo_root" && pwd -P)
current_root=$(pwd -P)
[ "$current_root" = "$repo_root" ] || fail "run from repository root: ${repo_root}"

base_branch=main
current_branch=$(git branch --show-current)
[ "$current_branch" = "$base_branch" ] || fail "current branch must be ${base_branch}, got ${current_branch:-detached}"
git rev-parse --verify --quiet "refs/heads/${base_branch}" >/dev/null || fail "missing local ${base_branch} branch"
[ -z "$(git status --porcelain)" ] || fail 'main worktree is not clean'
base_commit=$(git rev-parse "$base_branch")

task_file=$(find_task_file "$task_id")
task_status=$(read_field '- Status' "$task_file")
derived_ready=0
case "$task_status" in
  ready) ;;
  blocked)
    [ "$allow_derived_ready" -eq 1 ] || fail "${task_id} status must be ready, got blocked"
    task_allows_file "$task_file" "$task_file" || fail "derived-ready requires ${task_file} in its own Allowed Files"
    derived_ready=1
    ;;
  *) fail "${task_id} status must be ready, got ${task_status:-missing}" ;;
esac

depends_line=$(sed -n 's/^- Depends on: //p' "$task_file" | head -1)
dependencies=$(printf '%s\n' "$depends_line" | rg -o '[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+' 2>/dev/null || true)
while IFS= read -r dependency_id; do
  [ -n "$dependency_id" ] || continue
  dependency_file=$(find_task_file "$dependency_id")
  dependency_status=$(read_field '- Status' "$dependency_file")
  [ "$dependency_status" = done ] || fail "dependency ${dependency_id} must be done, got ${dependency_status:-missing}"
done <<EOF
$dependencies
EOF

refer_fingerprint=$(reference_fingerprint "$repo_root/refer")

# OMC v1 always uses exactly one worker per atomic Task. --no-decompose assigns
# the same task text to every requested worker, so more than one is redundant;
# parallelism lives across independent Tasks in batch waves, not within a Task.
workers=1

goal=$(task_goal "$task_file")
[ -n "$goal" ] || fail "missing Goal content in ${task_file}"

slug=$(printf '%s' "$task_id" | tr '[:upper:]_' '[:lower:]-')
branch="codex/omc-qs-${slug}"
session="omc-qs-${slug}"
worktree_root=${OMC_TASK_WORKTREE_ROOT:-"$(dirname "$repo_root")/$(basename "$repo_root")-task-worktrees"}
worktree="${worktree_root}/omc-${slug}"
minimum_free_kib=${OMC_MIN_FREE_KIB:-20971520}
[[ "$minimum_free_kib" =~ ^[0-9]+$ ]] || fail 'OMC_MIN_FREE_KIB must be a non-negative integer'
start_timeout=${OMC_START_TIMEOUT_SECONDS:-180}
[[ "$start_timeout" =~ ^[1-9][0-9]*$ ]] || fail 'OMC_START_TIMEOUT_SECONDS must be a positive integer'
[ "$start_timeout" -le 1800 ] || fail 'OMC_START_TIMEOUT_SECONDS must not exceed 1800'
tmux_columns=${OMC_TMUX_COLUMNS:-480}
tmux_rows=${OMC_TMUX_ROWS:-60}
[[ "$tmux_columns" =~ ^[1-9][0-9]*$ ]] || fail 'OMC_TMUX_COLUMNS must be a positive integer'
[[ "$tmux_rows" =~ ^[1-9][0-9]*$ ]] || fail 'OMC_TMUX_ROWS must be a positive integer'
[ "$tmux_columns" -ge 320 ] || fail 'OMC_TMUX_COLUMNS must be at least 320 so a split worker pane remains wide enough for delivery verification'
[ "$tmux_rows" -ge 40 ] || fail 'OMC_TMUX_ROWS must be at least 40 for worker delivery verification'

git_common_dir=$(git rev-parse --path-format=absolute --git-common-dir)
state_base="${git_common_dir}/omc-task-state/${slug}"

available_kib=$("$df_bin" -Pk "$repo_root" | awk 'NR == 2 { print $4 }')
[[ "$available_kib" =~ ^[0-9]+$ ]] || fail 'could not determine available disk space'
[ "$available_kib" -ge "$minimum_free_kib" ] || fail "insufficient disk: ${available_kib} KiB available, ${minimum_free_kib} KiB required"

created_worktree=0
created_state_base=0
tmux_started=0
leader_pane=
lock_acquired=0
launch_lock="${git_common_dir}/start-omc-task.lock"
cleanup_partial_launch() {
  rc=$?
  if [ "$rc" -ne 0 ]; then
    session_present=0
    if "$tmux_bin" has-session -t "$session" 2>/dev/null; then
      session_present=1
    fi
    stale_configs=$(find "$state_base" -type d -path '*/state/team/*/workers' 2>/dev/null || true)
    stale_count=$(printf '%s\n' "$stale_configs" | awk 'NF { count += 1 } END { print count + 0 }')
    # Remove deterministic resources only when no team state exists AND the entire
    # Task session is gone (no worker-backed session remains to inspect).
    if [ "$stale_count" -eq 0 ] && [ "$session_present" -eq 0 ] && [ "$created_worktree" -eq 1 ]; then
      git worktree remove --force "$worktree" >/dev/null 2>&1 || true
      git branch -D "$branch" >/dev/null 2>&1 || true
    fi
    if [ "$stale_count" -eq 0 ] && [ "$session_present" -eq 0 ] && [ "$created_state_base" -eq 1 ]; then
      rm -rf "$state_base" >/dev/null 2>&1 || true
    fi
  fi
  if [ "$lock_acquired" -eq 1 ]; then
    rmdir "$launch_lock" >/dev/null 2>&1 || true
  fi
  exit "$rc"
}
trap cleanup_partial_launch EXIT
if ! mkdir "$launch_lock" 2>/dev/null; then
  fail "another start-omc-task preflight is active or stale: ${launch_lock}"
fi
lock_acquired=1

git show-ref --verify --quiet "refs/heads/${branch}" && fail "branch already exists: ${branch}"
[ ! -e "$worktree" ] || fail "worktree path already exists: ${worktree}"
if "$tmux_bin" has-session -t "$session" 2>/dev/null; then
  fail "tmux session already exists: ${session}"
fi
active_task_sessions=$("$tmux_bin" list-sessions -F '#{session_name}' 2>/dev/null | awk '/^omc-qs-/ { count += 1 } END { print count + 0 }' || true)
active_task_sessions=${active_task_sessions:-0}
[ "$active_task_sessions" -lt 2 ] || fail "host already has ${active_task_sessions} omc-qs-* tmux sessions; maximum is 2"

if [ -d "$state_base" ]; then
  prior_teams=$(find "$state_base" -type d -path '*/state/team/*/workers' 2>/dev/null || true)
  prior_count=$(printf '%s\n' "$prior_teams" | awk 'NF { count += 1 } END { print count + 0 }')
  [ "$prior_count" -eq 0 ] || fail "stale OMC team state under ${state_base}; run ./scripts/finish-omc-task ${task_id} or remove the state base"
else
  mkdir -p "$state_base"
  created_state_base=1
fi

"$omc_bin" --version >/dev/null
"$tmux_bin" -V >/dev/null

team_task="Execute ${task_id} from ${task_file} as one atomic delivery with committed worker evidence held READY_FOR_LEADER_REVIEW until leader approval"
derived_instruction=
if [ "$derived_ready" -eq 1 ]; then
  derived_instruction=" The main branch still records blocked only because all named dependencies have just become done; commit the legal Task status transition from blocked to ready before any other Task write."
fi
prompt="${task_id}: act as the persistent Claude leader for exactly this one repository Task. Authoritative task file: ${task_file}. Desired outcome: ${goal}. Stay inside this Task integration worktree and do not exit after spawning workers. First read root AGENTS.md or CLAUDE.md, docs/glossary.md, docs/product/capability-map.md, docs/architecture/system-context.md, docs/tasks/README.md, the Task file, and nearest target AGENTS.md or README.md. Verify every dependency done.${derived_instruction} Then invoke the team through the exact atomic command: omc team 1:claude:executor --auto-merge --no-decompose \"${team_task}\". Do not add semicolons, bullets, or extra clauses to that team task string. After startup inspect the runtime tasks via cwd-bound omc team api get-summary and send non-overlapping assignments through team state or mailbox. The single worker must commit with the Lore protocol, report READY_FOR_LEADER_REVIEW, and keep its runtime task in_progress until you approve. Continuously poll cwd-bound omc team api get-summary so runtime auto-merge lands worker commits on the Task branch. Review the exact integrated HEAD independently, run every Task Verification Command plus local AGENTS or README checks, git diff --check, link or contract checks, and git status. PostgreSQL tasks require guarded PostgreSQL evidence and never SQLite. If verification fails, send concrete fixes and keep monitoring. Only after acceptance and all verification pass may you send APPROVED so the worker transitions terminal, mark the repository Task done, and write a final evidence report under .omc/context. Never modify refer/, credentials, logs, runtime data, sibling tasks, or another domain. Do not shut down the team after success; leave terminal team state and this Claude leader session available for operator inspection because the operator will run ./scripts/finish-omc-task ${task_id} from clean main to verify, shut down, rebase, merge, and clean resources."

print_summary() {
  mode=$1
  printf 'mode=%s\n' "$mode"
  printf 'task_id=%s\n' "$task_id"
  printf 'task_file=%s\n' "$task_file"
  printf 'workers=%s\n' "$workers"
  printf 'base_commit=%s\n' "$base_commit"
  printf 'derived_ready=%s\n' "$([ "$derived_ready" -eq 1 ] && printf true || printf false)"
  printf 'refer_fingerprint=%s\n' "$refer_fingerprint"
  printf 'branch=%s\n' "$branch"
  printf 'worktree=%s\n' "$worktree"
  printf 'tmux_session=%s\n' "$session"
  printf 'state_base=%s\n' "$state_base"
  [ -z "$leader_pane" ] || printf 'leader_pane=%s\n' "$leader_pane"
}

if [ "$dry_run" -eq 1 ]; then
  print_summary dry-run
  printf 'launch=persistent Claude leader -> omc team 1:claude:executor --auto-merge --no-decompose <atomic-task>\n'
  printf 'result=no resources created\n'
  rmdir "$launch_lock"
  lock_acquired=0
  trap - EXIT
  exit 0
fi

mkdir -p "$worktree_root"
git worktree add "$worktree" -b "$branch" "$base_branch" >/dev/null
created_worktree=1

stamp=$(date -u +%Y%m%dT%H%M%SZ)
context_file="${state_base}/${slug}-${stamp}.md"
prompt_file="${state_base}/${slug}-${stamp}.prompt.txt"
status_file="${state_base}/${slug}-${stamp}.startup-status.json"
launch_state_file="${state_base}/launch.json"
{
  printf '# %s OMC Team context\n\n' "$task_id"
  printf -- '- Task file: `%s`\n' "$task_file"
  printf -- '- Branch: `%s`\n' "$branch"
  printf -- '- Base commit: `%s`\n' "$base_commit"
  printf -- '- Workers: `1:claude:executor` (--no-decompose)\n'
  printf -- '- State base: `%s`\n' "$state_base"
  printf -- '- Desired outcome: %s\n' "$goal"
  printf -- '- Constraints: Allowed Files only; refer/ read-only; dependencies already done.\n'
} > "$context_file"
printf '%s\n' "$prompt" > "$prompt_file"
python3 - "$launch_state_file" "$task_id" "$task_file" "$base_commit" "$branch" "$worktree" "$session" "$state_base" "$derived_ready" "$refer_fingerprint" <<'PY'
import json
from pathlib import Path
import sys

path = Path(sys.argv[1])
payload = {
    "task_id": sys.argv[2],
    "task_file": sys.argv[3],
    "base_commit": sys.argv[4],
    "branch": sys.argv[5],
    "worktree": sys.argv[6],
    "session": sys.argv[7],
    "state_base": sys.argv[8],
    "derived_ready": sys.argv[9] == "1",
    "refer_fingerprint": sys.argv[10],
    "refer_fingerprint_version": "content-v2",
}
path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n")
PY

printf -v leader_command '%q ' \
  exec env "PATH=$(dirname "$tmux_shim"):${PATH}" "OMC_REAL_TMUX_BIN=${tmux_real_bin}" \
  "OMC_RUNTIME_V2=1" "OMC_STATE_DIR=${state_base}" "OMC_TEAM_WORKTREE_MODE=branch" "OMC_TEAM_NO_RC=1" \
  "$omc_bin" launch --madmax --notify false "$prompt"
leader_command=${leader_command% }
if ! leader_pane=$("$tmux_bin" new-session -d -P -F '#{pane_id}' \
  -x "$tmux_columns" -y "$tmux_rows" -s "$session" -c "$worktree" "$leader_command"); then
  if "$tmux_bin" has-session -t "$session" 2>/dev/null; then
    tmux_started=1
    fail "tmux session ${session} exists but its launch command returned an error; inspect it before recovery"
  fi
  fail "could not create tmux session: ${session}"
fi
tmux_started=1
[[ "$leader_pane" =~ ^%[0-9]+$ ]] || fail "tmux did not return a valid leader pane id: ${leader_pane:-missing}"
"$tmux_bin" set-window-option -t "${session}:0" window-size manual >/dev/null
"$tmux_bin" resize-window -t "${session}:0" -x "$tmux_columns" -y "$tmux_rows" >/dev/null
python3 - "$launch_state_file" "$leader_pane" <<'PY'
import json
from pathlib import Path
import sys

path = Path(sys.argv[1])
data = json.loads(path.read_text())
data["leader_pane"] = sys.argv[2]
path.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")
PY

leader_pane_alive() {
  pane_dead=$("$tmux_bin" display-message -p -t "$leader_pane" '#{pane_dead}' 2>/dev/null) || return 1
  [ "$pane_dead" = 0 ]
}

team_name=
status_json=

# Real OMC team state is a DIRECTORY under .../state/team/{teamName}/ (there is
# no config.json). A team dir contains a workers/ subdir. The same team may
# appear under the centralized OMC_STATE_DIR and a legacy <worktree>/.omc.
discover_team_candidates() {
  {
    find "$state_base" -type d -path '*/state/team/*/workers' 2>/dev/null || true
    if [ -d "$worktree/.omc/state/team" ]; then
      find "$worktree/.omc/state/team" -mindepth 2 -maxdepth 2 -type d -name workers 2>/dev/null || true
    fi
  } | sed -e 's#.*/state/team/##' -e 's#/workers$##' | awk 'NF && !seen[$0]++' | sort
}

summary_is_ready() {
  python3 -c '
import json
import sys

expected = int(sys.argv[1])
try:
    payload = json.load(sys.stdin)
except (json.JSONDecodeError, ValueError):
    raise SystemExit(1)
summary = (payload.get("data") or {}).get("summary") or {}
if not payload.get("ok") or not summary:
    raise SystemExit(1)
tasks = summary.get("tasks") or {}
workers = summary.get("workers") or []
nonrep = summary.get("nonReportingWorkers") or []
ready = (
    summary.get("workerCount") == expected
    and isinstance(tasks.get("total"), int)
    and tasks.get("total") >= 1
    and len(workers) == expected
    and all(bool(w.get("alive")) for w in workers)
    and len(nonrep) == 0
)
raise SystemExit(0 if ready else 1)
' "$1"
}

for (( second = 0; second < start_timeout; second += 1 )); do
  # Auto-accept Claude Code's fresh-worktree folder-trust prompt so the
  # non-interactive leader does not hang (--madmax does not dismiss it).
  if pane_text=$("$tmux_bin" capture-pane -t "$leader_pane" -p 2>/dev/null); then
    if printf '%s\n' "$pane_text" | grep -qi 'trust this folder'; then
      "$tmux_bin" send-keys -t "$leader_pane" Enter 2>/dev/null || true
    fi
  fi

  candidates=$(discover_team_candidates)
  candidate_count=$(printf '%s\n' "$candidates" | awk 'NF { count += 1 } END { print count + 0 }')
  ready_team=
  if [ "$candidate_count" -ge 1 ]; then
    while IFS= read -r candidate_name; do
      [ -n "$candidate_name" ] || continue
      [[ "$candidate_name" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]] || continue
      candidate_json=$(cd "$worktree" && OMC_RUNTIME_V2=1 OMC_STATE_DIR="$state_base" OMC_TEAM_WORKTREE_MODE=branch \
        "$omc_bin" team api get-summary --input "{\"team_name\":\"${candidate_name}\"}" --json 2>/dev/null) || candidate_json=
      if [ -n "$candidate_json" ] && printf '%s' "$candidate_json" | summary_is_ready "$workers"; then
        if [ -n "$ready_team" ]; then
          fail "multiple ready OMC teams appeared under ${state_base}; inspect ${session} before recovery"
        fi
        ready_team=$candidate_name
        status_json=$candidate_json
      fi
    done <<EOF
$candidates
EOF
  fi
  if [ -n "$ready_team" ]; then
    if ! leader_pane_alive; then
      fail "persistent Claude leader exited after OMC team state appeared; inspect ${worktree} before recovery"
    fi
    team_name=$ready_team
    break
  fi
  if ! leader_pane_alive; then
    if [ "$candidate_count" -eq 0 ]; then
      if "$tmux_bin" has-session -t "$session" 2>/dev/null; then
        fail "persistent Claude leader pane exited before OMC team state appeared while ${session} still has panes; inspect it before recovery"
      fi
      tmux_started=0
      leader_pane=
      fail "persistent Claude leader exited before creating OMC team state"
    fi
    fail "persistent Claude leader exited after OMC team state appeared; inspect ${worktree} before recovery"
  fi
  sleep 1
done

if [ -z "$team_name" ]; then
  printf 'ERROR: persistent Claude leader did not produce a ready OMC team within %s seconds\n' "$start_timeout" >&2
  print_summary recovery-required >&2
  printf 'leader_prompt=%s\n' "$prompt_file" >&2
  printf 'inspect=tmux attach -t %s\n' "$session" >&2
  exit 1
fi

printf '%s\n' "$status_json" > "$status_file"
omc_version=$("$omc_bin" --version 2>/dev/null | head -1 || printf 'unknown')
python3 - "$launch_state_file" "$leader_pane" "$team_name" "$omc_version" <<'PY'
import json
from pathlib import Path
import sys

path = Path(sys.argv[1])
data = json.loads(path.read_text())
data["leader_pane"] = sys.argv[2]
data["team_name"] = sys.argv[3]
data["omc_version"] = sys.argv[4]
path.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")
PY
rmdir "$launch_lock"
lock_acquired=0
trap - EXIT
print_summary started
printf 'team_name=%s\n' "$team_name"
printf 'context=%s\n' "$context_file"
printf 'leader_prompt=%s\n' "$prompt_file"
printf 'launch_json=%s\n' "$launch_state_file"
printf 'startup_status=%s\n' "$status_file"
printf '\nMonitor:\n'
printf '(cd %q && OMC_RUNTIME_V2=1 OMC_STATE_DIR=%q OMC_TEAM_WORKTREE_MODE=branch omc team api get-summary --input %q --json)\n' \
  "$worktree" "$state_base" "{\"team_name\":\"${team_name}\"}"
printf 'tmux attach -t %q\n' "$session"
printf '\nFinish only after terminal team status and leader final evidence:\n'
printf 'finish=./scripts/finish-omc-task %q\n' "$task_id"
